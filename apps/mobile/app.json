{
  "expo": {
    "name": "Clario Astrology",
    "slug": "clario",
    "scheme": "clario",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0D1117"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "by.tryclario.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Уведомления сообщают о готовности вашего астрологического разбора."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "by.tryclario.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "src/app"
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7c3aed"
        }
      ],
      "expo-localization",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false,
        "root": "src/app"
      },
      "eas": {
        "projectId": "5d4b1503-b818-4dd0-a2a0-5c63fd5678c2"
      }
    }
  }
}
